# Application
APP_NAME=NexusCRM API
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:3000"]

# Database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexuscrm

# Auth — CHANGE THIS IN PRODUCTION to a long random string
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string-at-least-32-chars

# JWT expiry
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Event-Driven Onboarding Service
EVENT_SERVICE_URL=http://localhost:8081
EVENT_SERVICE_API_KEY=change-me-in-production

# Semantic Search Service
SEARCH_SERVICE_URL=http://localhost:8082

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
